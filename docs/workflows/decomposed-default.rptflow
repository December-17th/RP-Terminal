{
  "id": "decomposed-default-example",
  "name": "Decomposed Generation",
  "version": 1,
  "schemaVersion": 1,
  "description": "The default pipeline with the prompt built from visible components instead of the opaque Assemble Prompt node: card + persona + lorebook search compose a system frame, history and the pending user action follow as messages. Edit the 'frame' node to reshape the prompt. This example forgoes the assemble node's ST-faithful assembly BY DESIGN, for legibility: the ST preset prompt-order walk, the prompt regex passes, and budget trimming now live in the prompt.assemble Prompt port (wire that node, or a messages.trim node, to opt back in) — here History count (12) is the cap. Cache-level freezing is the one semantic that remains unimplemented anywhere.",
  "nodes": [
    { "id": "ctx", "type": "input.context", "position": { "x": 0, "y": 380 } },
    { "id": "action", "type": "context.action", "position": { "x": 280, "y": 40 } },
    { "id": "params", "type": "context.params", "position": { "x": 280, "y": 180 } },
    {
      "id": "card",
      "type": "context.card",
      "config": { "field": "all", "expand": true },
      "position": { "x": 280, "y": 320 }
    },
    {
      "id": "persona",
      "type": "context.persona",
      "config": { "expand": true },
      "position": { "x": 280, "y": 460 }
    },
    {
      "id": "history",
      "type": "context.history",
      "config": { "count": 12 },
      "position": { "x": 280, "y": 600 }
    },
    {
      "id": "lore-q",
      "type": "text.template",
      "config": { "template": "{{in1}}\n{{in2}}" },
      "position": { "x": 560, "y": 40 }
    },
    {
      "id": "lore",
      "type": "tool.lorebookSearch",
      "config": { "max_entries": 8 },
      "position": { "x": 840, "y": 40 }
    },
    {
      "id": "frame",
      "type": "prompt.messages",
      "config": {
        "messages": [
          {
            "role": "system",
            "content": "You are {{char}}. Continue the roleplay with {{user}}, staying in character.\n\n[Character]\n{{in1}}\n\n[{{user}}'s persona]\n{{in2}}\n\n[World information]\n{{in3}}"
          }
        ]
      },
      "position": { "x": 840, "y": 380 }
    },
    {
      "id": "user-msg",
      "type": "prompt.messages",
      "config": { "messages": [{ "role": "user", "content": "{{in1}}" }] },
      "position": { "x": 840, "y": 620 }
    },
    { "id": "merge", "type": "merge.messages", "position": { "x": 1120, "y": 380 } },
    { "id": "llm", "type": "llm.sample", "position": { "x": 1400, "y": 380 } },
    { "id": "parse", "type": "parse.response", "position": { "x": 1680, "y": 380 } },
    { "id": "apply", "type": "apply.state", "position": { "x": 1960, "y": 380 } },
    {
      "id": "write",
      "type": "output.writeFloor",
      "isMainOutput": true,
      "position": { "x": 2240, "y": 380 }
    }
  ],
  "edges": [
    { "from": { "node": "ctx", "port": "gen" }, "to": { "node": "action", "port": "gen" } },
    { "from": { "node": "ctx", "port": "gen" }, "to": { "node": "params", "port": "gen" } },
    { "from": { "node": "ctx", "port": "gen" }, "to": { "node": "card", "port": "gen" } },
    { "from": { "node": "ctx", "port": "gen" }, "to": { "node": "persona", "port": "gen" } },
    { "from": { "node": "ctx", "port": "gen" }, "to": { "node": "history", "port": "gen" } },

    { "from": { "node": "action", "port": "text" }, "to": { "node": "lore-q", "port": "in1" } },
    {
      "from": { "node": "history", "port": "transcript" },
      "to": { "node": "lore-q", "port": "in2" }
    },
    { "from": { "node": "ctx", "port": "gen" }, "to": { "node": "lore", "port": "gen" } },
    { "from": { "node": "lore-q", "port": "text" }, "to": { "node": "lore", "port": "query" } },

    { "from": { "node": "ctx", "port": "gen" }, "to": { "node": "frame", "port": "gen" } },
    { "from": { "node": "card", "port": "text" }, "to": { "node": "frame", "port": "in1" } },
    { "from": { "node": "persona", "port": "text" }, "to": { "node": "frame", "port": "in2" } },
    { "from": { "node": "lore", "port": "block" }, "to": { "node": "frame", "port": "in3" } },

    { "from": { "node": "ctx", "port": "gen" }, "to": { "node": "user-msg", "port": "gen" } },
    { "from": { "node": "action", "port": "text" }, "to": { "node": "user-msg", "port": "in1" } },

    { "from": { "node": "ctx", "port": "gen" }, "to": { "node": "merge", "port": "gen" } },
    { "from": { "node": "frame", "port": "messages" }, "to": { "node": "merge", "port": "a" } },
    { "from": { "node": "history", "port": "messages" }, "to": { "node": "merge", "port": "b" } },
    { "from": { "node": "user-msg", "port": "messages" }, "to": { "node": "merge", "port": "c" } },

    { "from": { "node": "ctx", "port": "gen" }, "to": { "node": "llm", "port": "gen" } },
    {
      "from": { "node": "merge", "port": "messages" },
      "to": { "node": "llm", "port": "sendMessages" }
    },
    { "from": { "node": "params", "port": "params" }, "to": { "node": "llm", "port": "params" } },

    { "from": { "node": "ctx", "port": "gen" }, "to": { "node": "parse", "port": "gen" } },
    { "from": { "node": "llm", "port": "raw" }, "to": { "node": "parse", "port": "raw" } },
    {
      "from": { "node": "merge", "port": "messages" },
      "to": { "node": "parse", "port": "sendMessages" }
    },
    { "from": { "node": "llm", "port": "rawUsage" }, "to": { "node": "parse", "port": "rawUsage" } },

    { "from": { "node": "ctx", "port": "gen" }, "to": { "node": "apply", "port": "gen" } },
    { "from": { "node": "parse", "port": "parsed" }, "to": { "node": "apply", "port": "parsed" } },
    { "from": { "node": "parse", "port": "mvu" }, "to": { "node": "apply", "port": "mvu" } },
    { "from": { "node": "llm", "port": "raw" }, "to": { "node": "apply", "port": "raw" } },

    { "from": { "node": "ctx", "port": "gen" }, "to": { "node": "write", "port": "gen" } },
    { "from": { "node": "llm", "port": "raw" }, "to": { "node": "write", "port": "raw" } },
    {
      "from": { "node": "merge", "port": "messages" },
      "to": { "node": "write", "port": "sendMessages" }
    },
    { "from": { "node": "apply", "port": "variables" }, "to": { "node": "write", "port": "variables" } },
    { "from": { "node": "parse", "port": "parsed" }, "to": { "node": "write", "port": "parsed" } },
    { "from": { "node": "parse", "port": "metrics" }, "to": { "node": "write", "port": "metrics" } }
  ]
}
