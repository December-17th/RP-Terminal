{
  "id": "poem-party-panel",
  "scriptName": "命定之诗-队伍面板",
  "findRegex": "<队伍面板/>",
  "replaceString": "<!--\n  命定之诗 — party-avatar panel (BG3-style), standalone panel-area regex SOURCE. v2.\n  Renders a dark, gilded, DRAGGABLE vertical strip of the party = 主角 (always) + a manual\n  member list (NOT everyone 在场). Edit the party via the ＋管理队伍 picker (toggles 关系列表 NPCs).\n  Click any portrait → detail overlay (立绘 + identity + 好感度/性格 + 状态效果 + vital shell).\n  Membership + strip position persist PER-CHAT in the type:'chat' card KV\n  (party.members / party.stripPos), read via getVariables({type:'chat'}) and written via\n  updateVariablesWith(updater,{type:'chat'}). Character data: getVariables().stat_data.\n  Portraits: window.assetUrl(name, type, mood?) → rptasset:// URL or null.\n  Vital bars are a STATIC SHELL — no data binding (companions have no 生命/法力/体力 in MVU).\n  Delivered as a DOCKED WCV panel (loaded once, NOT re-injected per message), so it renders\n  on load and then re-renders on stat_data changes via eventOn('mag_variable_updated'/'message_updated')\n  — that's how it catches 主角 being initialised at session start.\n  VERIFY rendering + data-read in-app (manual-verify).\n-->\n<div id=\"poem-pp-root\" class=\"poem-pp\">\n  <div class=\"poem-pp-strip\" id=\"poem-pp-strip\">\n    <div class=\"poem-pp-loading\">载入…</div>\n  </div>\n</div>\n\n<!-- Detail overlay (shared, populated per-member) -->\n<div id=\"poem-pp-overlay\" class=\"poem-pp-overlay poem-pp-hidden\" role=\"dialog\" aria-modal=\"true\">\n  <div class=\"poem-pp-overlay-backdrop\" id=\"poem-pp-backdrop\"></div>\n  <div class=\"poem-pp-overlay-sheet\" id=\"poem-pp-sheet\">\n    <button class=\"poem-pp-close\" id=\"poem-pp-close\" aria-label=\"关闭\">✕</button>\n    <div class=\"poem-pp-overlay-body\" id=\"poem-pp-overlay-body\"></div>\n  </div>\n</div>\n\n<style>\n  /* ── tokens ──────────────────────────────────────────────────────\n     Defined on BOTH roots: #poem-pp-overlay is a SIBLING of #poem-pp-root\n     (not a descendant), so without this the overlay subtree can't resolve\n     var(--…) — every color falls back to inherited black on the dark sheet\n     (the dark-on-dark bug). The overlay's own later rules keep its\n     position:fixed / display, so listing it here only shares the tokens. */\n  .poem-pp,\n  .poem-pp-overlay {\n    --bg:        #18140f;\n    --card:      #251c14;\n    --border:    #5a412a;\n    --window:    #130f0a;\n    --gold:      #c9a84c;\n    --gold-hi:   #e8cc6e;\n    --gold-lo:   #7a5e2a;\n    --t1:        #f4e3c8;\n    --t2:        #c8a87a;\n    --t3:        #8a6e52;\n    --hp:        #b73a2b;\n    --mp:        #2d5aa0;\n    --sp:        #3b7f52;\n    --hero-ring: #e8cc6e;\n    --comp-ring: #8a9fc8;\n    --overlay-bg:#0d0a07ee;\n  }\n  .poem-pp {\n    font-family: 'Noto Sans SC', 'Noto Serif SC', serif;\n    display: block;\n    position: relative;\n  }\n\n  /* ── strip ───────────────────────────────────────────────────── */\n  .poem-pp-strip {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 10px;\n    padding: 10px 6px;\n    background: linear-gradient(180deg, #1e1710 0%, #130f0a 100%);\n    border: 1px solid var(--border);\n    border-radius: 10px;\n    width: 76px;\n    box-shadow:\n      inset 0 1px 0 rgba(201,168,76,.18),\n      inset 0 -1px 0 rgba(0,0,0,.5),\n      0 2px 12px rgba(0,0,0,.6);\n    position: fixed;\n    left: 8px;\n    top: 8px;\n    z-index: 50;\n  }\n  .poem-pp-drag {\n    width: 100%;\n    height: 14px;\n    margin-bottom: 4px;\n    cursor: grab;\n    border-radius: 4px;\n    background: linear-gradient(90deg, transparent, rgba(201,168,76,.5), transparent);\n    flex-shrink: 0;\n  }\n  .poem-pp-drag:active { cursor: grabbing; }\n  .poem-pp-manage {\n    margin-top: 8px;\n    font-size: 10px;\n    color: #c8a87a;\n    border: 1px solid #5a412a;\n    border-radius: 4px;\n    padding: 3px 4px;\n    text-align: center;\n    cursor: pointer;\n    width: 58px;\n  }\n  .poem-pp-manage:hover { color: #f4e3c8; border-color: #7a5e2a; }\n  .poem-pp-mg-list { display: flex; flex-direction: column; gap: 6px; }\n  .poem-pp-mg-row { display: flex; align-items: center; gap: 8px; color: #f4e3c8; font-size: 13px; cursor: pointer; }\n  .poem-pp-strip::before {\n    content: '';\n    position: absolute;\n    top: 0; left: 0; right: 0;\n    height: 2px;\n    background: linear-gradient(90deg, transparent, var(--gold), transparent);\n    border-radius: 10px 10px 0 0;\n    opacity: .7;\n  }\n  .poem-pp-loading {\n    color: var(--t3);\n    font-size: 11px;\n    padding: 8px 0;\n  }\n\n  /* ── member card in strip ────────────────────────────────────── */\n  .poem-pp-member {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 4px;\n    cursor: pointer;\n    user-select: none;\n    -webkit-user-select: none;\n  }\n  .poem-pp-member:hover .poem-pp-frame {\n    box-shadow:\n      0 0 0 1px var(--gold-hi),\n      0 0 8px rgba(201,168,76,.45),\n      inset 0 0 6px rgba(0,0,0,.6);\n  }\n\n  /* gilded portrait frame */\n  .poem-pp-frame {\n    position: relative;\n    width: 58px;\n    height: 58px;\n    border-radius: 6px;\n    box-shadow:\n      0 0 0 2px var(--border),\n      0 0 0 3px var(--gold-lo),\n      0 0 0 4px var(--border),\n      inset 0 0 8px rgba(0,0,0,.7);\n    overflow: hidden;\n    flex-shrink: 0;\n    transition: box-shadow .18s ease;\n  }\n  .poem-pp-frame.hero-frame {\n    box-shadow:\n      0 0 0 2px var(--border),\n      0 0 0 3px var(--hero-ring),\n      0 0 0 4px var(--border),\n      0 0 8px rgba(232,204,110,.3),\n      inset 0 0 8px rgba(0,0,0,.7);\n  }\n  /* engraved corner ornaments */\n  .poem-pp-frame::before,\n  .poem-pp-frame::after {\n    content: '';\n    position: absolute;\n    width: 10px; height: 10px;\n    border: 2px solid;\n    border-color: var(--gold-lo);\n    z-index: 3;\n    pointer-events: none;\n  }\n  .poem-pp-frame::before {\n    top: 2px; left: 2px;\n    border-right: none; border-bottom: none;\n  }\n  .poem-pp-frame::after {\n    bottom: 2px; right: 2px;\n    border-left: none; border-top: none;\n  }\n\n  .poem-pp-portrait {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    display: block;\n    position: relative;\n    z-index: 1;\n  }\n  /* mood tint overlay */\n  .poem-pp-mood-tint {\n    position: absolute;\n    inset: 0;\n    z-index: 2;\n    pointer-events: none;\n    border-radius: inherit;\n  }\n\n  /* placeholder (initial/emblem) */\n  .poem-pp-placeholder {\n    width: 100%;\n    height: 100%;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    background: radial-gradient(ellipse at 50% 30%, #2e2318 0%, #130f0a 100%);\n    font-size: 22px;\n    color: var(--gold);\n    font-weight: 700;\n    letter-spacing: 0;\n    text-shadow: 0 1px 6px rgba(0,0,0,.8), 0 0 12px rgba(201,168,76,.4);\n    position: relative;\n    z-index: 1;\n  }\n  .poem-pp-placeholder::after {\n    content: '';\n    position: absolute;\n    inset: 6px;\n    border: 1px solid rgba(201,168,76,.2);\n    border-radius: 3px;\n    pointer-events: none;\n  }\n\n  /* name label */\n  .poem-pp-name {\n    font-size: 10px;\n    color: var(--t2);\n    text-align: center;\n    max-width: 64px;\n    white-space: nowrap;\n    overflow: hidden;\n    text-overflow: ellipsis;\n    letter-spacing: .03em;\n    text-shadow: 0 1px 2px #000;\n  }\n  .poem-pp-member.is-hero .poem-pp-name {\n    color: var(--gold);\n  }\n\n  /* vital bars shell (strip) — static, no values */\n  .poem-pp-vitals-mini {\n    display: flex;\n    flex-direction: column;\n    gap: 2px;\n    width: 58px;\n  }\n  .poem-pp-vbar-mini {\n    height: 4px;\n    border-radius: 2px;\n    background: var(--window);\n    border: 1px solid rgba(90,65,42,.5);\n    overflow: hidden;\n    position: relative;\n  }\n  .poem-pp-vbar-mini::after {\n    content: '';\n    position: absolute;\n    inset: 0;\n    background: linear-gradient(90deg, rgba(255,255,255,.06) 0%, transparent 100%);\n  }\n  .poem-pp-vbar-mini.hp-bar { border-color: rgba(183,58,43,.35); }\n  .poem-pp-vbar-mini.mp-bar { border-color: rgba(45,90,160,.35); }\n  .poem-pp-vbar-mini.sp-bar { border-color: rgba(59,127,82,.35); }\n\n  /* ── overlay ─────────────────────────────────────────────────── */\n  .poem-pp-overlay {\n    position: fixed;\n    inset: 0;\n    z-index: 9999;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n  .poem-pp-overlay.poem-pp-hidden {\n    display: none;\n  }\n  .poem-pp-overlay-backdrop {\n    position: absolute;\n    inset: 0;\n    background: var(--overlay-bg);\n    backdrop-filter: blur(3px);\n  }\n  .poem-pp-overlay-sheet {\n    position: relative;\n    z-index: 1;\n    width: min(540px, 92vw);\n    max-height: 88vh;\n    overflow-y: auto;\n    background: linear-gradient(160deg, #1f1810 0%, #130f0a 60%, #0d0a07 100%);\n    border: 1px solid var(--border);\n    border-radius: 12px;\n    box-shadow:\n      0 0 0 1px var(--gold-lo),\n      0 0 40px rgba(0,0,0,.85),\n      inset 0 1px 0 rgba(201,168,76,.15),\n      inset 0 -1px 0 rgba(0,0,0,.4);\n    padding: 0 0 20px;\n    /* decorative top border */\n    background-image:\n      linear-gradient(160deg, #1f1810 0%, #130f0a 60%, #0d0a07 100%);\n  }\n  .poem-pp-overlay-sheet::before {\n    content: '';\n    display: block;\n    height: 2px;\n    background: linear-gradient(90deg, transparent, var(--gold), transparent);\n    border-radius: 12px 12px 0 0;\n    opacity: .8;\n  }\n  .poem-pp-close {\n    position: absolute;\n    top: 10px; right: 12px;\n    background: none;\n    border: 1px solid var(--border);\n    border-radius: 4px;\n    color: var(--t3);\n    font-size: 13px;\n    width: 24px; height: 24px;\n    cursor: pointer;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    z-index: 2;\n    transition: color .15s, border-color .15s;\n    padding: 0;\n    line-height: 1;\n  }\n  .poem-pp-close:hover {\n    color: var(--t1);\n    border-color: var(--gold-lo);\n  }\n\n  /* overlay body layout */\n  .poem-pp-overlay-body {\n    padding: 16px 20px 0;\n  }\n\n  /* 立绘 section */\n  .poem-pp-ow-portrait-wrap {\n    display: flex;\n    gap: 18px;\n    align-items: flex-start;\n    margin-bottom: 14px;\n  }\n  .poem-pp-ow-portrait-frame {\n    flex-shrink: 0;\n    width: 120px;\n    height: 180px;\n    border-radius: 8px;\n    position: relative;\n    box-shadow:\n      0 0 0 2px var(--border),\n      0 0 0 3px var(--gold-lo),\n      0 0 0 4px var(--border),\n      0 4px 24px rgba(0,0,0,.7),\n      inset 0 0 12px rgba(0,0,0,.6);\n    overflow: hidden;\n    background: #130f0a;\n  }\n  .poem-pp-ow-portrait-frame::before,\n  .poem-pp-ow-portrait-frame::after {\n    content: '';\n    position: absolute;\n    width: 14px; height: 14px;\n    border: 2px solid var(--gold-lo);\n    z-index: 3;\n    pointer-events: none;\n  }\n  .poem-pp-ow-portrait-frame::before {\n    top: 3px; left: 3px;\n    border-right: none; border-bottom: none;\n  }\n  .poem-pp-ow-portrait-frame::after {\n    bottom: 3px; right: 3px;\n    border-left: none; border-top: none;\n  }\n  .poem-pp-ow-portrait {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    display: block;\n    position: relative;\n    z-index: 1;\n  }\n  .poem-pp-ow-placeholder {\n    width: 100%;\n    height: 100%;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 48px;\n    color: var(--gold);\n    background: radial-gradient(ellipse at 50% 30%, #2e2318 0%, #130f0a 100%);\n    text-shadow: 0 0 20px rgba(201,168,76,.4);\n    position: relative;\n    z-index: 1;\n  }\n\n  /* right-side identity */\n  .poem-pp-ow-info {\n    flex: 1;\n    min-width: 0;\n    padding-top: 4px;\n  }\n  .poem-pp-ow-name {\n    font-size: 18px;\n    font-weight: 700;\n    color: var(--gold);\n    letter-spacing: .05em;\n    margin-bottom: 4px;\n    text-shadow: 0 1px 6px rgba(0,0,0,.6);\n  }\n  .poem-pp-ow-name.hero-name {\n    color: var(--gold-hi);\n  }\n  .poem-pp-ow-identity {\n    font-size: 12px;\n    color: var(--t2);\n    margin-bottom: 10px;\n    line-height: 1.6;\n  }\n  .poem-pp-ow-identity span {\n    display: inline-block;\n    margin-right: 6px;\n  }\n  .poem-pp-ow-identity .dot {\n    color: var(--t3);\n    margin: 0 2px;\n  }\n\n  /* 好感度 / 性格 */\n  .poem-pp-ow-affinity {\n    display: flex;\n    flex-wrap: wrap;\n    gap: 6px;\n    margin-bottom: 10px;\n  }\n  .poem-pp-ow-pill {\n    background: var(--card);\n    border: 1px solid var(--border);\n    border-radius: 4px;\n    padding: 3px 8px;\n    font-size: 11px;\n    color: var(--t2);\n    line-height: 1.4;\n  }\n  .poem-pp-ow-pill b {\n    color: var(--t1);\n  }\n  .poem-pp-ow-pill.affinity-val {\n    border-color: var(--gold-lo);\n  }\n\n  /* vital bars shell (overlay) */\n  .poem-pp-ow-vitals {\n    margin-bottom: 12px;\n  }\n  .poem-pp-ow-sect {\n    font-size: 11px;\n    color: var(--gold);\n    letter-spacing: .05em;\n    margin-bottom: 5px;\n    border-bottom: 1px solid var(--border);\n    padding-bottom: 2px;\n    opacity: .8;\n  }\n  .poem-pp-vbar-row {\n    display: flex;\n    align-items: center;\n    gap: 6px;\n    margin-bottom: 4px;\n  }\n  .poem-pp-vbar-label {\n    font-size: 10px;\n    color: var(--t3);\n    width: 16px;\n    text-align: right;\n    flex-shrink: 0;\n  }\n  .poem-pp-vbar {\n    flex: 1;\n    height: 10px;\n    border-radius: 5px;\n    background: var(--window);\n    border: 1px solid rgba(90,65,42,.5);\n    position: relative;\n    overflow: hidden;\n  }\n  .poem-pp-vbar::before {\n    /* inset sheen */\n    content: '';\n    position: absolute;\n    top: 0; left: 0; right: 0;\n    height: 4px;\n    background: linear-gradient(180deg, rgba(255,255,255,.1) 0%, transparent 100%);\n    z-index: 1;\n  }\n  .poem-pp-vbar.hp-bar { border-color: rgba(183,58,43,.45); }\n  .poem-pp-vbar.mp-bar { border-color: rgba(45,90,160,.45); }\n  .poem-pp-vbar.sp-bar { border-color: rgba(59,127,82,.45); }\n  .poem-pp-vbar-dash {\n    font-size: 10px;\n    color: var(--t3);\n    flex-shrink: 0;\n    font-style: italic;\n  }\n\n  /* 状态效果 */\n  .poem-pp-ow-states {\n    margin-bottom: 6px;\n  }\n  .poem-pp-state-row {\n    display: flex;\n    flex-wrap: wrap;\n    gap: 5px;\n  }\n  .poem-pp-state-chip {\n    background: var(--window);\n    border: 1px solid var(--border);\n    border-radius: 4px;\n    padding: 3px 7px;\n    font-size: 11px;\n    color: var(--t2);\n    line-height: 1.4;\n  }\n  .poem-pp-state-chip .st-name {\n    color: var(--t1);\n    font-weight: 600;\n  }\n  .poem-pp-state-chip .st-meta {\n    color: var(--t3);\n    margin-left: 3px;\n  }\n  .poem-pp-empty {\n    color: var(--t3);\n    font-size: 11px;\n    font-style: italic;\n  }\n\n  /* divider */\n  .poem-pp-divider {\n    height: 1px;\n    background: linear-gradient(90deg, transparent, var(--border), transparent);\n    margin: 12px 0;\n    opacity: .6;\n  }\n</style>\n\n<script>\n  ;(function () {\n    /* ── helpers ───────────────────────────────────────────────── */\n    function esc(s) {\n      return String(s == null ? '' : s).replace(/[&<>\"]/g, function (c) {\n        return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '\"': '&quot;' }[c]\n      })\n    }\n    function initial(name) {\n      var s = String(name || '?')\n      return s.charAt(0)\n    }\n    function moodTint(mood) {\n      var MAP = {\n        愤怒: 'rgba(180,40,30,.22)',\n        悲伤: 'rgba(50,80,180,.22)',\n        恐惧: 'rgba(80,0,120,.2)',\n        喜悦: 'rgba(220,180,40,.15)',\n        平静: 'rgba(40,120,80,.12)',\n      }\n      return MAP[mood] || null\n    }\n\n    /* ── data access (mirrors poem-combat-sheet.html gv()) ──────── */\n    function gv() {\n      try {\n        var v = typeof getVariables === 'function'\n          ? (getVariables({ type: 'message' }) || getVariables() || {})\n          : {}\n        /* getVariables may return a Promise; handle both sync and async */\n        if (v && typeof v.then === 'function') {\n          return v.then(function (r) { return (r || {}).stat_data || {} })\n        }\n        return Promise.resolve((v || {}).stat_data || {})\n      } catch (e) {\n        try {\n          var v2 = typeof getVariables === 'function' ? (getVariables() || {}) : {}\n          if (v2 && typeof v2.then === 'function') {\n            return v2.then(function (r) { return (r || {}).stat_data || {} })\n          }\n          return Promise.resolve((v2 || {}).stat_data || {})\n        } catch (_) {\n          return Promise.resolve({})\n        }\n      }\n    }\n\n    /* resolve portrait via window.assetUrl (TavernHelper page API) */\n    function resolveAsset(name, type, mood) {\n      try {\n        if (typeof window.assetUrl === 'function') {\n          var result = window.assetUrl(name, type, mood)\n          if (result && typeof result.then === 'function') return result\n          return Promise.resolve(result || null)\n        }\n      } catch (_) {}\n      return Promise.resolve(null)\n    }\n\n    /* ── DOM refs ───────────────────────────────────────────────── */\n    var stripEl    = document.getElementById('poem-pp-strip')\n    var overlayEl  = document.getElementById('poem-pp-overlay')\n    var backdropEl = document.getElementById('poem-pp-backdrop')\n    var closeBtn   = document.getElementById('poem-pp-close')\n    var bodyEl     = document.getElementById('poem-pp-overlay-body')\n    if (!stripEl || !overlayEl) return\n\n    /* ── overlay helpers ────────────────────────────────────────── */\n    function openOverlay() { overlayEl.classList.remove('poem-pp-hidden') }\n    function closeOverlay() { overlayEl.classList.add('poem-pp-hidden') }\n\n    closeBtn.addEventListener('click', closeOverlay)\n    backdropEl.addEventListener('click', closeOverlay)\n    document.addEventListener('keydown', function (e) {\n      if (e.key === 'Escape') closeOverlay()\n    })\n\n    /* ── vital bar shell (overlay) ──────────────────────────────── */\n    function vitalShell() {\n      return (\n        '<div class=\"poem-pp-ow-vitals\">' +\n        '<div class=\"poem-pp-ow-sect\">生命 · 法力 · 体力</div>' +\n        vbar('HP', 'hp-bar') +\n        vbar('MP', 'mp-bar') +\n        vbar('SP', 'sp-bar') +\n        '</div>'\n      )\n    }\n    function vbar(label, cls) {\n      return (\n        '<div class=\"poem-pp-vbar-row\">' +\n        '<span class=\"poem-pp-vbar-label\">' + label + '</span>' +\n        '<div class=\"poem-pp-vbar ' + cls + '\"></div>' +\n        '<span class=\"poem-pp-vbar-dash\">—</span>' +\n        '</div>'\n      )\n    }\n\n    /* ── state effect chips ─────────────────────────────────────── */\n    function stateChips(states) {\n      /* guard against a malformed 状态效果 being an array (would render\n         numeric-index chips); fall back to {} */\n      if (Array.isArray(states)) states = {}\n      var keys = Object.keys(states || {})\n      if (!keys.length) {\n        return '<div class=\"poem-pp-empty\">无状态效果</div>'\n      }\n      return keys.map(function (k) {\n        var s = states[k] || {}\n        var meta = []\n        if (s['层数'] != null) meta.push('×' + esc(s['层数']))\n        if (s['剩余时间'] != null) meta.push(esc(s['剩余时间']))\n        return (\n          '<span class=\"poem-pp-state-chip\">' +\n          '<span class=\"st-name\">' + esc(k) + '</span>' +\n          (meta.length ? '<span class=\"st-meta\">' + meta.join(' ') + '</span>' : '') +\n          '</span>'\n        )\n      }).join('')\n    }\n\n    /* ── overlay population ─────────────────────────────────────── */\n    function showDetail(member) {\n      var name  = member.name\n      var data  = member.data || {}\n      var isHero = member.isHero\n\n      /* identity line */\n      var job   = esc(data['职业'] || data['身份'] || '')\n      var lvl   = esc(data['等级'] != null ? '等级 ' + data['等级'] : '')\n      var tier  = esc(data['生命层级'] || '')\n      var identParts = [job, lvl, tier].filter(Boolean)\n\n      /* affinity / personality (companions only) */\n      var affPills = ''\n      if (!isHero) {\n        var aff = data['好感度']\n        var per = data['性格']\n        if (aff != null) {\n          affPills += '<span class=\"poem-pp-ow-pill affinity-val\">好感度 <b>' + esc(aff) + '</b></span>'\n        }\n        if (per != null) {\n          affPills += '<span class=\"poem-pp-ow-pill\">性格 <b>' + esc(per) + '</b></span>'\n        }\n      } else {\n        var heroClass = data['职业'] || data['身份'] || ''\n        if (heroClass) {\n          affPills += '<span class=\"poem-pp-ow-pill\"><b>' + esc(heroClass) + '</b></span>'\n        }\n      }\n\n      /* 状态效果 */\n      var states = data['状态效果'] || {}\n\n      /* build inner HTML (立绘 loaded async below) */\n      var nameClass = isHero ? 'poem-pp-ow-name hero-name' : 'poem-pp-ow-name'\n      bodyEl.innerHTML = (\n        '<div class=\"poem-pp-ow-portrait-wrap\">' +\n        '<div class=\"poem-pp-ow-portrait-frame\" id=\"poem-pp-ow-pf\">' +\n        '<div class=\"poem-pp-ow-placeholder\" id=\"poem-pp-ow-ph\">' + esc(initial(name)) + '</div>' +\n        '</div>' +\n        '<div class=\"poem-pp-ow-info\">' +\n        '<div class=\"' + nameClass + '\">' + esc(name) + '</div>' +\n        '<div class=\"poem-pp-ow-identity\">' +\n        identParts.map(function (p, i) {\n          return (i > 0 ? '<span class=\"dot\">·</span>' : '') + '<span>' + p + '</span>'\n        }).join('') +\n        '</div>' +\n        (affPills ? '<div class=\"poem-pp-ow-affinity\">' + affPills + '</div>' : '') +\n        vitalShell() +\n        '</div>' +\n        '</div>' +\n        '<div class=\"poem-pp-divider\"></div>' +\n        '<div class=\"poem-pp-ow-states\">' +\n        '<div class=\"poem-pp-ow-sect\">状态效果</div>' +\n        '<div class=\"poem-pp-state-row\">' + stateChips(states) + '</div>' +\n        '</div>'\n      )\n\n      openOverlay()\n\n      /* async: load 立绘 */\n      var mood = data['当前情绪'] || data['心情'] || undefined\n      resolveAsset(name, '立绘', mood).then(function (url) {\n        var ph = document.getElementById('poem-pp-ow-ph')\n        var pf = document.getElementById('poem-pp-ow-pf')\n        if (!pf) return\n        if (url) {\n          var img = document.createElement('img')\n          img.className = 'poem-pp-ow-portrait'\n          img.alt = name\n          img.src = url\n          if (ph && ph.parentNode === pf) {\n            pf.replaceChild(img, ph)\n          } else {\n            pf.insertBefore(img, pf.firstChild)\n          }\n        }\n        /* if no URL, placeholder stays */\n      })\n    }\n\n    /* ── strip rendering ────────────────────────────────────────── */\n    function renderStrip(party) {\n      /* 主角 is always present, so an empty party still renders the drag handle +\n         ＋管理队伍 button (the entry point for adding the first member). */\n      stripEl.innerHTML = ''\n\n      /* drag handle + restore saved position */\n      var handle = document.createElement('div')\n      handle.className = 'poem-pp-drag'\n      handle.title = '拖动'\n      stripEl.appendChild(handle)\n      applyStripPos()\n      enableDrag(handle)\n\n      party.forEach(function (member) {\n        var name   = member.name\n        var isHero = member.isHero\n        var data   = member.data || {}\n        var mood   = data['当前情绪'] || data['心情'] || undefined\n\n        var memberEl = document.createElement('div')\n        memberEl.className = 'poem-pp-member' + (isHero ? ' is-hero' : '')\n        memberEl.title = name\n\n        /* frame */\n        var frameEl = document.createElement('div')\n        frameEl.className = 'poem-pp-frame' + (isHero ? ' hero-frame' : '')\n\n        /* placeholder (shown until portrait loads) */\n        var phEl = document.createElement('div')\n        phEl.className = 'poem-pp-placeholder'\n        phEl.textContent = initial(name)\n        frameEl.appendChild(phEl)\n\n        /* mood tint overlay */\n        var tintColor = moodTint(mood)\n        if (tintColor) {\n          var tintEl = document.createElement('div')\n          tintEl.className = 'poem-pp-mood-tint'\n          tintEl.style.background = tintColor\n          frameEl.appendChild(tintEl)\n        }\n\n        memberEl.appendChild(frameEl)\n\n        /* name */\n        var nameEl = document.createElement('div')\n        nameEl.className = 'poem-pp-name'\n        nameEl.textContent = name\n        memberEl.appendChild(nameEl)\n\n        /* vital bar shell (strip — 3 thin bars, no labels, no data) */\n        var vitalsEl = document.createElement('div')\n        vitalsEl.className = 'poem-pp-vitals-mini'\n        vitalsEl.innerHTML = (\n          '<div class=\"poem-pp-vbar-mini hp-bar\"></div>' +\n          '<div class=\"poem-pp-vbar-mini mp-bar\"></div>' +\n          '<div class=\"poem-pp-vbar-mini sp-bar\"></div>'\n        )\n        memberEl.appendChild(vitalsEl)\n\n        /* click → overlay */\n        memberEl.addEventListener('click', function () { showDetail(member) })\n\n        stripEl.appendChild(memberEl)\n\n        /* async: load 头像 portrait */\n        resolveAsset(name, '头像', mood).then(function (url) {\n          if (url) {\n            var img = document.createElement('img')\n            img.className = 'poem-pp-portrait'\n            img.alt = name\n            img.src = url\n            /* insert before mood-tint (or at position 0 if no tint) */\n            if (phEl.parentNode === frameEl) {\n              frameEl.insertBefore(img, phEl)\n              /* keep placeholder until image loads, then hide it */\n              img.onload = function () {\n                phEl.style.display = 'none'\n              }\n              img.onerror = function () {\n                img.parentNode && img.parentNode.removeChild(img)\n              }\n            }\n          }\n          /* no URL → placeholder stays */\n        })\n      })\n\n      /* manage button at bottom of strip */\n      var mgBtn = document.createElement('div')\n      mgBtn.className = 'poem-pp-manage'\n      mgBtn.textContent = '＋ 管理队伍'\n      mgBtn.title = '从已知角色添加/移除队员'\n      mgBtn.addEventListener('click', showManage)\n      stripEl.appendChild(mgBtn)\n    }\n\n    /* per-chat card KV (getVariables({type:'chat'})) — SYNC in both transports */\n    function chatKV() {\n      try {\n        var v = typeof getVariables === 'function' ? getVariables({ type: 'chat' }) : {}\n        return v && typeof v === 'object' && typeof v.then !== 'function' ? v : {}\n      } catch (_) { return {} }\n    }\n    function partyMembers() {\n      var m = chatKV()['party.members']\n      return Array.isArray(m) ? m : []\n    }\n\n    /* ── build party from stat_data ─────────────────────────────── */\n    /* party = 主角 (always) + the manual party.members list (NOT 关系列表-在场) */\n    function buildParty(SD) {\n      var hero = SD['主角'] || null\n      var rel  = SD['关系列表'] || {}\n      var party = []\n      if (hero) {\n        party.push({ name: hero['姓名'] || hero['名称'] || '主角', data: hero, isHero: true })\n      }\n      partyMembers().forEach(function (n) {\n        party.push({ name: n, data: rel[n] || {}, isHero: false })\n      })\n      return party\n    }\n\n    /* persist a single chat-KV key without clobbering siblings */\n    function setKV(key, value) {\n      try {\n        if (typeof updateVariablesWith === 'function') {\n          return updateVariablesWith(function (prev) {\n            var next = prev && typeof prev === 'object' ? prev : {}\n            next[key] = value\n            return next\n          }, { type: 'chat' })\n        }\n      } catch (_) {}\n      return Promise.resolve()\n    }\n\n    function setParty(members) {\n      return setKV('party.members', members).then(refresh)\n    }\n\n    /* manage overlay: every known NPC (关系列表 keys) with a toggle; checked = in party */\n    function showManage() {\n      gv().then(function (SD) {\n        var rel = SD['关系列表'] || {}\n        var inParty = partyMembers()\n        var names = Object.keys(rel)\n        var rows = names.length\n          ? names.map(function (n) {\n              var on = inParty.indexOf(n) >= 0\n              return (\n                '<label class=\"poem-pp-mg-row\">' +\n                '<input type=\"checkbox\" data-name=\"' + esc(n) + '\"' + (on ? ' checked' : '') + '>' +\n                '<span>' + esc(n) + '</span></label>'\n              )\n            }).join('')\n          : '<div class=\"poem-pp-empty\">暂无已知角色（关系列表为空）</div>'\n        bodyEl.innerHTML =\n          '<div class=\"poem-pp-ow-sect\" style=\"margin:4px 0 10px\">管理队伍</div>' +\n          '<div class=\"poem-pp-mg-list\">' + rows + '</div>'\n        openOverlay()\n        var boxes = bodyEl.querySelectorAll('input[type=checkbox]')\n        Array.prototype.forEach.call(boxes, function (b) {\n          b.addEventListener('change', function () {\n            var cur = partyMembers().slice()\n            var nm = b.getAttribute('data-name')\n            var i = cur.indexOf(nm)\n            if (b.checked && i < 0) cur.push(nm)\n            if (!b.checked && i >= 0) cur.splice(i, 1)\n            setParty(cur)\n          })\n        })\n      })\n    }\n\n    /* ── drag helpers ───────────────────────────────────────────── */\n    function clamp(v, lo, hi) { return v < lo ? lo : v > hi ? hi : v }\n    function applyStripPos() {\n      var p = chatKV()['party.stripPos']\n      var w = stripEl.offsetWidth || 76, h = stripEl.offsetHeight || 120\n      var x = p && typeof p.x === 'number' ? p.x : 8\n      var y = p && typeof p.y === 'number' ? p.y : 8\n      stripEl.style.left = clamp(x, 0, Math.max(0, window.innerWidth - w)) + 'px'\n      stripEl.style.top  = clamp(y, 0, Math.max(0, window.innerHeight - h)) + 'px'\n    }\n    function enableDrag(handle) {\n      var sx = 0, sy = 0, ox = 0, oy = 0, dragging = false\n      function down(e) {\n        dragging = true\n        sx = e.clientX; sy = e.clientY\n        ox = parseInt(stripEl.style.left || '8', 10)\n        oy = parseInt(stripEl.style.top || '8', 10)\n        document.addEventListener('pointermove', move)\n        document.addEventListener('pointerup', up)\n        e.preventDefault()\n      }\n      function move(e) {\n        if (!dragging) return\n        var w = stripEl.offsetWidth, h = stripEl.offsetHeight\n        var nx = clamp(ox + (e.clientX - sx), 0, Math.max(0, window.innerWidth - w))\n        var ny = clamp(oy + (e.clientY - sy), 0, Math.max(0, window.innerHeight - h))\n        stripEl.style.left = nx + 'px'\n        stripEl.style.top = ny + 'px'\n      }\n      function up() {\n        dragging = false\n        document.removeEventListener('pointermove', move)\n        document.removeEventListener('pointerup', up)\n        setKV('party.stripPos', {\n          x: parseInt(stripEl.style.left || '8', 10),\n          y: parseInt(stripEl.style.top || '8', 10)\n        })\n      }\n      handle.addEventListener('pointerdown', down)\n    }\n\n    /* ── initial render ─────────────────────────────────────────── */\n    function refresh() {\n      gv().then(function (SD) {\n        var party = buildParty(SD)\n        renderStrip(party)\n      })\n    }\n\n    /* Initial render, THEN re-render on stat_data changes. This panel is a DOCKED\n       WCV that loads its HTML ONCE — it is NOT re-injected per message like the\n       inline combat sheet — so without a listener it would render before MVU\n       initialises 主角 at session start and never catch it. The shared runtime\n       re-emits every host var-change as both `mag_variable_updated` (MVU) and\n       `message_updated` (tavern); we coalesce that pair into one refresh per tick.\n       refresh() only READS + renders (it never writes stat_data), so there is no\n       write-back loop. */\n    refresh()\n    if (typeof eventOn === 'function') {\n      var pendingRefresh = false\n      var onVarsChanged = function () {\n        if (pendingRefresh) return\n        pendingRefresh = true\n        Promise.resolve().then(function () { pendingRefresh = false; refresh() })\n      }\n      eventOn('mag_variable_updated', onVarsChanged)\n      eventOn('message_updated', onVarsChanged)\n    }\n\n  })()\n</script>\n",
