{
  "id": "poem-combat-sheet",
  "scriptName": "命定之诗-战斗面板",
  "findRegex": "<战斗状态栏/>",
  "replaceString": "<div id=\"poem-cs-root\" class=\"poem-cs\">载入战斗面板…</div>\n\n<style>\n  .poem-cs {\n    --bg: #221912; --card: #2c2016; --border: #5a412a; --window: #1c1410;\n    --t1: #f4e3c8; --t2: #d2b48c; --t3: #a1886b;\n    --hp: #b73a2b; --mp: #305fa8; --sp: #3b7f52;\n    --q-common: #e4d6bb; --q-uncommon: #519767; --q-rare: #578ccb; --q-epic: #9a79cc;\n    --q-legendary: #e1c067; --q-mythic: #cd6b7e; --q-unique: #d6a057;\n    font-family: 'Noto Sans SC', sans-serif; color: var(--t1);\n    background: var(--bg); border: 1px solid color-mix(in srgb, var(--border) 80%, transparent);\n    border-radius: 10px; padding: 12px 14px; line-height: 1.5; font-size: 13px;\n  }\n  .poem-cs h3 { margin: 0 0 2px; font-size: 15px; color: var(--t1); letter-spacing: .04em; }\n  .poem-cs .sub { color: var(--t3); font-size: 11px; margin-bottom: 10px; }\n  .poem-cs .bars { display: grid; gap: 5px; margin-bottom: 10px; }\n  .poem-cs .bar { position: relative; height: 16px; border-radius: 4px; background: var(--window);\n    border: 1px solid var(--border); overflow: hidden; }\n  .poem-cs .bar > i { position: absolute; inset: 0; display: block; opacity: .85; }\n  .poem-cs .bar > span { position: relative; z-index: 1; font-size: 10px; padding: 0 6px;\n    display: flex; justify-content: space-between; color: #fff; text-shadow: 0 1px 2px #000a; }\n  .poem-cs .attrs { display: grid; grid-template-columns: repeat(5, 1fr); gap: 6px; margin-bottom: 10px; }\n  .poem-cs .attr { background: var(--card); border: 1px solid var(--border); border-radius: 6px;\n    text-align: center; padding: 5px 2px; }\n  .poem-cs .attr b { display: block; font-size: 16px; color: var(--t1); }\n  .poem-cs .attr small { color: var(--t3); font-size: 10px; }\n  .poem-cs .derived { display: flex; flex-wrap: wrap; gap: 6px 12px; margin-bottom: 12px;\n    color: var(--t2); font-size: 12px; }\n  .poem-cs .derived b { color: var(--t1); }\n  .poem-cs .sect { font-size: 12px; color: var(--q-legendary); margin: 12px 0 6px;\n    border-bottom: 1px solid var(--border); padding-bottom: 3px; letter-spacing: .05em; }\n  .poem-cs .ab { background: var(--card); border: 1px solid var(--border); border-left-width: 3px;\n    border-radius: 6px; padding: 7px 9px; margin-bottom: 6px; }\n  .poem-cs .ab .nm { font-weight: 600; }\n  .poem-cs .ab .meta { color: var(--t2); font-size: 11px; margin-top: 2px; }\n  .poem-cs .ab .meta .tag { display: inline-block; background: var(--window); border: 1px solid var(--border);\n    border-radius: 3px; padding: 0 5px; margin: 2px 4px 0 0; color: var(--t2); }\n  .poem-cs .ab .desc { color: var(--t3); font-size: 11px; margin-top: 3px; }\n  .poem-cs .empty { color: var(--t3); font-size: 11px; font-style: italic; }\n  .poem-cs .status { display: flex; flex-wrap: wrap; gap: 4px; }\n  .poem-cs .status .s { background: var(--window); border: 1px solid var(--border); border-radius: 3px;\n    padding: 1px 6px; font-size: 11px; color: var(--t2); }\n</style>\n\n<script>\n  (function () {\n    var root = document.getElementById('poem-cs-root');\n    if (!root) return;\n    function gv() {\n      try { return (getVariables({ type: 'message' }) || getVariables() || {}).stat_data || {}; }\n      catch (e) { try { return (getVariables() || {}).stat_data || {}; } catch (_) { return {}; } }\n    }\n    var SD = gv();\n    var P = SD['主角'] || {};\n\n    // --- derive tables (mirror of src/shared/combat — keep in sync) ---\n    var TIER_COEF = { 1: 2, 2: 2.8, 3: 4, 4: 8, 5: 15, 6: 35, 7: 80 };\n    var QMAP = { 普通: 'common', 优良: 'uncommon', 稀有: 'rare', 史诗: 'epic', 传说: 'legendary', 神话: 'mythic', 唯一: 'unique' };\n    var CN = { 一: 1, 二: 2, 三: 3, 四: 4, 五: 5, 六: 6, 七: 7 };\n    var ATTRS = ['力量', '敏捷', '体质', '智力', '精神'];\n    function num(v, d) { if (typeof v === 'number') return v; var m = String(v == null ? '' : v).match(/-?\\d+(\\.\\d+)?/); return m ? parseFloat(m[0]) : (d || 0); }\n    function tier(lv, lvl) { var m = String(lv || '').match(/[一二三四五六七]/); if (m) return CN[m[0]]; var n = num(lvl); return n > 0 ? Math.min(7, Math.max(1, Math.ceil(n / 4))) : 1; }\n    function esc(s) { return String(s == null ? '' : s).replace(/[&<>]/g, function (c) { return { '&': '&amp;', '<': '&lt;', '>': '&gt;' }[c]; }); }\n\n    // --- compact parseCardItem (mirror; reads 标签/效果/消耗 + scans flavor prose) ---\n    function parseItem(it) {\n      it = it || {}; var o = { 命中: 0, 闪避: 0, DR: 0, 伤害增幅: 0, 护盾: 0, 治疗增幅: 0, 治疗量: 0, 附加效果: [] };\n      (Array.isArray(it.标签) ? it.标签 : []).forEach(function (raw) {\n        var t = String(raw || '').trim(), m;\n        if (ATTRS.indexOf(t) >= 0) o.关联属性 = t;\n        else if ((m = t.match(/有效距离[:：]?\\s*(\\d+)/))) o.有效距离 = +m[1];\n        else if ((m = t.match(/威力[:：]?\\s*(\\d+)/))) o.威力 = +m[1];\n        else if ((m = t.match(/攻击[:：]?\\s*(\\d+)/))) o.攻击 = +m[1];\n        else if ((m = t.match(/防御[:：]?\\s*(\\d+)/))) o.防御 = +m[1];\n        else if (/治疗/.test(t)) o.治疗 = true;\n        else if (/范围|爆发|直线|锥形/.test(t)) o.范围 = t.replace(/范围[:：]?\\s*/, '');\n        else if (/单体|自身/.test(t)) o.范围 = '单体';\n        else if (!o.关联属性) { var a = ATTRS.filter(function (x) { return t.indexOf(x) >= 0; })[0]; if (a) o.关联属性 = a; }\n      });\n      var eff = it.效果 && typeof it.效果 === 'object' ? it.效果 : {};\n      Object.keys(eff).forEach(function (k) {\n        var v = String(eff[k] == null ? '' : eff[k]), m;\n        if (/命中/.test(k)) o.命中 = Math.max(o.命中, num(v));\n        else if (/闪避/.test(k)) o.闪避 = Math.max(o.闪避, num(v));\n        else if (/固伤|额外固定/.test(k)) o.固伤 = (o.固伤 || 0) + num(v);\n        else if (/^DR$|减伤/.test(k)) o.DR = Math.max(o.DR, num(v));\n        else if (/穿透/.test(k)) o.穿透 = num(v);\n        else if (/伤害增幅|增伤/.test(k)) o.伤害增幅 += num(v);\n        else if (/护盾/.test(k)) o.护盾 += num(v);\n        else if (/治疗增幅/.test(k)) o.治疗增幅 += num(v);\n        else if (/治疗|恢复/.test(k)) o.治疗量 += num(v);\n        else if ((m = v.match(/(\\d+)\\s*\\+?\\s*(\\d+)?\\s*回合/))) o.附加效果.push(k + '(' + (m[2] ? m[1] + '/' + m[2] + '回合' : m[1] + '回合') + ')');\n        else {\n          // flavor prose scan\n          if ((m = v.match(/(?:提高|增加|提升)\\s*(\\d+(?:\\.\\d+)?)\\s*%\\s*治疗/))) o.治疗增幅 += parseFloat(m[1]);\n          else if ((m = v.match(/(?:提高|增加|提升)\\s*(\\d+(?:\\.\\d+)?)\\s*%\\s*(?:伤害|攻击)/))) o.伤害增幅 += parseFloat(m[1]);\n          if (/减伤|(?:减少|降低)[^。]*伤害|伤害[^。]*(?:减少|降低)/.test(v) && (m = v.match(/(\\d+(?:\\.\\d+)?)\\s*%/))) o.DR = Math.max(o.DR, parseFloat(m[1]));\n          if ((m = v.match(/(\\d+)\\s*点?\\s*护盾/))) o.护盾 += +m[1];\n          if ((m = v.match(/额外(?:造成|附加)?\\s*(\\d+)\\s*点[^，。]*?伤害/))) o.固伤 = (o.固伤 || 0) + (+m[1]);\n        }\n      });\n      return o;\n    }\n\n    // --- render ---\n    var T = tier(P['生命层级'], P['等级']);\n    var A = P['属性'] || {};\n    var coef = TIER_COEF[T] || 1;\n    var weaponAtk = 0, def = 0, hit = 0, dodge = 0, shield = 0;\n    Object.keys(P['装备'] || {}).forEach(function (slot) {\n      var c = parseItem(P['装备'][slot]);\n      if (c.攻击) weaponAtk = Math.max(weaponAtk, c.攻击);\n      if (c.防御) def += c.防御;\n      hit = Math.max(hit, c.命中); dodge = Math.max(dodge, c.闪避); shield += c.护盾 || 0;\n    });\n\n    function bar(label, cur, max, color) {\n      var pct = max > 0 ? Math.max(0, Math.min(100, (cur / max) * 100)) : 0;\n      return '<div class=\"bar\"><i style=\"width:' + pct + '%;background:' + color + '\"></i>' +\n        '<span><b>' + label + '</b><b>' + cur + ' / ' + max + '</b></span></div>';\n    }\n    function attrCell(a) { return '<div class=\"attr\"><b>' + num(A[a]) + '</b><small>' + a + '</small></div>'; }\n\n    function abilityCard(name, it) {\n      var c = parseItem(it);\n      var q = QMAP[it.品质] || 'common';\n      var meta = [];\n      if (c.威力) meta.push('威力 ' + c.威力);\n      if (c.关联属性) meta.push(c.关联属性);\n      meta.push('射程 ' + (c.有效距离 || 1));\n      if (c.范围) meta.push(c.范围);\n      if (it.消耗) meta.push('消耗 ' + String(it.消耗).replace(/\\s+/g, ''));\n      if (c.治疗) meta.push('治疗');\n      var mods = [];\n      if (c.命中) mods.push('命中+' + c.命中);\n      if (c.伤害增幅) mods.push('伤害+' + c.伤害增幅 + '%');\n      if (c.治疗增幅) mods.push('治疗+' + c.治疗增幅 + '%');\n      if (c.DR) mods.push('减伤' + c.DR + '%');\n      if (c.穿透) mods.push('穿透' + c.穿透 + '%');\n      if (c.护盾) mods.push('护盾' + c.护盾);\n      if (c.固伤) mods.push('固伤' + c.固伤);\n      (c.附加效果 || []).forEach(function (s) { mods.push(s); });\n      return '<div class=\"ab\" style=\"border-left-color:var(--q-' + q + ')\">' +\n        '<div class=\"nm\" style=\"color:var(--q-' + q + ')\">' + esc(name) + '</div>' +\n        '<div class=\"meta\">' + meta.map(function (m) { return '<span class=\"tag\">' + esc(m) + '</span>'; }).join('') +\n        (mods.length ? '<div>' + mods.map(esc).join(' · ') + '</div>' : '') + '</div>' +\n        (it.描述 ? '<div class=\"desc\">' + esc(it.描述) + '</div>' : '') + '</div>';\n    }\n\n    var skills = P['技能'] || {}, equips = P['装备'] || {}, states = P['状态效果'] || {};\n    var html = '';\n    html += '<h3>' + esc(P['姓名'] || '主角') + ' · 战斗面板</h3>';\n    html += '<div class=\"sub\">' + esc(P['生命层级'] || ('第' + T + '层级')) + ' · 等级 ' + num(P['等级'], 1) + ' · 层级系数 ×' + coef + '</div>';\n    html += '<div class=\"bars\">' +\n      bar('HP', num(P['生命值']), num(P['生命值上限']) || num(P['生命值']), 'var(--hp)') +\n      bar('MP', num(P['法力值']), num(P['法力值上限']) || num(P['法力值']), 'var(--mp)') +\n      bar('SP', num(P['体力值']), num(P['体力值上限']) || num(P['体力值']), 'var(--sp)') + '</div>';\n    html += '<div class=\"attrs\">' + ATTRS.map(attrCell).join('') + '</div>';\n    html += '<div class=\"derived\"><span>武器攻击 <b>' + weaponAtk + '</b></span><span>防御 <b>' + def + '</b></span>' +\n      '<span>命中 <b>+' + hit + '</b></span><span>闪避 <b>+' + dodge + '</b></span>' +\n      (shield ? '<span>护盾 <b>' + shield + '</b></span>' : '') + '</div>';\n\n    html += '<div class=\"sect\">技能</div>';\n    var sk = Object.keys(skills);\n    html += sk.length ? sk.map(function (n) { return abilityCard(n, skills[n]); }).join('') : '<div class=\"empty\">无</div>';\n\n    html += '<div class=\"sect\">装备</div>';\n    var eq = Object.keys(equips);\n    html += eq.length ? eq.map(function (n) { return abilityCard(n, equips[n]); }).join('') : '<div class=\"empty\">无</div>';\n\n    var st = Object.keys(states);\n    if (st.length) {\n      html += '<div class=\"sect\">状态</div><div class=\"status\">' +\n        st.map(function (n) { var s = states[n] || {}; return '<span class=\"s\">' + esc(n) + (s.剩余时间 ? ' (' + esc(s.剩余时间) + ')' : '') + '</span>'; }).join('') + '</div>';\n    }\n\n    root.innerHTML = html;\n  })();\n</script>\n",
  "trimStrings": [],
  "placement": [2],
  "disabled": false,
  "markdownOnly": true,
  "promptOnly": false,
  "runOnEdit": true,
  "substituteRegex": 0,
  "minDepth": null,
  "maxDepth": null
}
