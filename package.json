{
  "name": "rp-terminal",
  "productName": "RP Terminal",
  "version": "0.2.0",
  "description": "Desktop client for sophisticated AI roleplay (SillyTavern-compatible)",
  "main": "./out/main/index.js",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "check:deps": "depcruise src --config .dependency-cruiser.cjs",
    "check:docs": "node scripts/check-doc-links.mjs",
    "check:package": "node scripts/verify-package.mjs",
    "check:release": "node scripts/verify-package.mjs --require-artifact",
    "check:release:mac": "node scripts/verify-package.mjs --mac --require-artifact",
    "verify": "npm run typecheck && npm run check:deps && npm run test",
    "test": "vitest run",
    "test:watch": "vitest",
    "tune:lore": "node -e \"require('child_process').execSync('vitest run test/loreScoringTuner.test.ts',{stdio:'inherit',env:Object.assign({},process.env,{TUNE_LORE:'1'})})\"",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir && npm run check:package",
    "build:win": "npm run build && electron-builder --win zip --publish never && npm run check:release",
    "build:mac": "npm run build && electron-builder --mac zip --publish never && npm run check:release:mac",
    "build:linux": "electron-vite build && electron-builder --linux"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@jitl/quickjs-singlefile-browser-release-sync": "^0.32.0",
    "adm-zip": "^0.5.17",
    "better-sqlite3": "^12.11.1",
    "jquery": "^4.0.0",
    "lodash": "^4.18.1",
    "pinia": "^3.0.4",
    "quickjs-emscripten": "^0.32.0",
    "uuid": "^14.0.0",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@formkit/auto-animate": "^0.9.0",
    "@testing-library/react": "^16.3.2",
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dompurify": "^3.0.5",
    "@types/jquery": "^4.0.1",
    "@types/lodash": "^4.17.24",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.1.1",
    "dependency-cruiser": "^18.0.0",
    "dompurify": "^3.4.11",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "typescript": "^5.9.3",
    "vanilla-jsoneditor": "3.12.0",
    "vite": "^7.2.6",
    "vitest": "^4.1.9",
    "zustand": "^5.0.14"
  }
}
